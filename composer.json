{
	"name": "pmdawn/dementor-blocks",
	"description": "Audit and convert Elementor-built pages into native WordPress blocks.",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"autoload": {
		"psr-4": {
			"DementorBlocks\\": "src/"
		}
	},
	"authors": [
		{
			"name": "PM Dawn - blueflymedia",
			"homepage": "https://blueflymedia.com"
		}
	],
	"require": {
		"php": ">=8.4"
	},
	"require-dev": {
		"phpunit/phpunit": "^9.6",
		"yoast/phpunit-polyfills": "^2.0"
	},
	"scripts": {
		"test": "phpunit",
		"lint": [
			"@php -l dementor-blocks.php"
		]
	}
}
